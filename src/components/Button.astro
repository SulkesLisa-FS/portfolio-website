---
interface Props {
  href: string;
  external?: boolean;
}
const { href, external = false } = Astro.props;
const rel = external ? "noopener noreferrer" : undefined;
const target = external ? "_blank" : undefined;
---
<a
  href={href}
  target={target}
  rel={rel}
  class="inline-flex items-center justify-center rounded-xl border border-accent/30
         bg-surface/50 px-6 py-3 text-lg font-medium tracking-wide text-foreground
         transition duration-200
         hover:border-accent hover:text-accent
         hover:shadow-[0_0_20px_-2px_rgb(var(--glow)/0.5)]
         focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
>
  <slot />
</a>