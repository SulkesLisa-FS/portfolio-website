---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

// Generate a static page for every article in the collection.
export async function getStaticPaths() {
  const posts = await getCollection("insights");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const formattedDate = post.data.pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout
  title={`${post.data.title} — Lisa Sulkes`}
  description={post.data.summary}
>
  <div class="mx-auto w-full max-w-3xl px-6 pt-10">
    <a
      href="/insights"
      class="inline-flex items-center gap-2 text-lg text-muted transition hover:text-accent"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="shrink-0"
      >
        <path d="M19 12H5"></path>
        <path d="m12 19-7-7 7-7"></path>
      </svg>
      Back to Insights
    </a>
  </div>

  <article class="mx-auto w-full max-w-3xl px-6 py-12">
    <time datetime={post.data.pubDate.toISOString()} class="text-sm text-muted">
      {formattedDate}
    </time>
    <h1
      class="mt-2 font-display text-3xl font-semibold text-heading sm:text-4xl"
    >
      {post.data.title}
    </h1>

    <div class="article-body mt-8 flex flex-col text-foreground">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .article-body :global(h2) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-display, inherit);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-heading, currentColor);
  }
  .article-body :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-heading, currentColor);
  }
  .article-body :global(p) {
    margin-bottom: 1rem;
    line-height: 1.75;
  }
  .article-body :global(ul),
  .article-body :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    list-style: revert;
  }
  .article-body :global(li) {
    margin-bottom: 0.25rem;
  }
  .article-body :global(a) {
    color: var(--color-accent, currentColor);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .article-body :global(code) {
    border-radius: 0.375rem;
    background: rgb(255 255 255 / 0.08);
    padding: 0.15rem 0.35rem;
    font-size: 0.9em;
  }
  .article-body :global(blockquote) {
    margin: 1.5rem 0;
    border-left: 3px solid var(--color-accent, currentColor);
    padding-left: 1rem;
    font-style: italic;
    color: var(--color-muted, currentColor);
  }
</style>
